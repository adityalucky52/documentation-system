// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

/**
 * Model: User
 * Represents an authenticated author or team member in the system.
 * 
 * Features:
 * - Credentials verification and session matching.
 * - One-to-one organization ownership relationship.
 * - Triggered by client pages: LoginPage, RegisterPage.
 */
model User {
  id           String        @id @default(uuid())
  email        String        @unique // User identity email key
  name         String?       // Friendly display name
  password     String        // Bcrypt hashed credential
  organization Organization? // Organization owned by this user
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

/**
 * Model: Organization
 * A workspace container that groups documentation sites, sites setup configurations,
 * and associated authors.
 * 
 * Relationships:
 * - One User owner (UserId references User.id).
 * - Has many Sites.
 * - Triggered by: CreateOrganizationPage, DashboardLayout syncs.
 */
model Organization {
  id        String   @id
  name      String
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  sites     Site[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * Model: Site
 * A high-level documentation site (e.g., "Developer Portal").
 * 
 * Relationships:
 * - Belongs to one Organization (organizationId references Organization.id).
 * - Has many Spaces (sub-document sections).
 * - Triggered by: CreateSiteModal, SiteSetupPage.
 */
model Site {
  id             String       @id
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  spaces         Space[]
  isSetup        Boolean      @default(false) // Toggle between template onboarding checks vs dashboard overview tabs
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

/**
 * Model: Space
 * A sub-workspace section under a site (e.g., "API Docs" vs "User Guides").
 * Acts as the logical repository for Git-style page branching operations.
 * 
 * Relationships:
 * - Belongs to one Site (siteId references Site.id).
 * - Has many pages (Page) representing the live master branch states.
 * - Has many branches (Branch) and change requests (ChangeRequest).
 * - Triggered by: SpaceEditorPage.
 */
model Space {
  id             String          @id
  name           String
  siteId         String
  site           Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pages          Page[]
  branches       Branch[]
  mergeLogs      MergeLog[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

/**
 * Model: Page
 * Represents the live/published master content of a documentation document.
 * 
 * Relationships:
 * - Belongs to a Space (spaceId references Space.id).
 * - Has many PageVersions representing current or past edits mapped to specific branches.
 * - Triggered by: EditorCanvas, EditorSidebar.
 */
model Page {
  id        String        @id
  title     String
  content   String        @default("")
  spaceId   String
  space     Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  versions  PageVersion[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}



/**
 * Model: Branch
 * Isolated Git-style branch reference tracking a collection of document page modifications.
 * 
 * Relationships:
 * - Belongs to one Space (spaceId references Space.id).
 * - Has many PageVersions (isolated edits).
 * - Referenced by ChangeRequest as source and target branch.
 */
model Branch {
  id                   String          @id
  name                 String          // e.g. "main", "change-request-123"
  spaceId              String
  space                Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  pageVersions         PageVersion[]
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}



/**
 * Model: PageVersion
 * Isolated content record for a Page inside a specific Branch.
 * Ensures edits made on drafts do not override the live main Page content until merged.
 * 
 * Key Constraints:
 * - Unique combination of pageId and branchId, guaranteeing one draft version per page per branch.
 * - Triggered by: Editor autosaves, TipTap modifications.
 */
model PageVersion {
  id        String   @id @default(uuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title     String
  content   String   @default("")
  updatedAt DateTime @updatedAt

  @@unique([pageId, branchId])
}

/**
 * Model: MergeLog
 * Tracks successful space-level publish events (copying draft versions to master).
 */
model MergeLog {
  id        String   @id @default(uuid())
  spaceId   String
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  title     String
  mergedBy  String
  createdAt DateTime @default(now())
}


