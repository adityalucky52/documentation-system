// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  password     String
  organization Organization?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Organization {
  id        String   @id
  name      String
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  sites     Site[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Site {
  id             String       @id
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  spaces         Space[]
  isSetup        Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Space {
  id             String          @id
  name           String
  siteId         String
  site           Site            @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pages          Page[]
  branches       Branch[]
  changeRequests ChangeRequest[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Page {
  id        String        @id
  title     String
  content   String        @default("")
  spaceId   String
  space     Space         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  versions  PageVersion[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum ChangeRequestStatus {
  DRAFT
  OPEN
  MERGED
  CLOSED
}

model Branch {
  id                   String          @id
  name                 String          // e.g. "main", "change-request-123"
  spaceId              String
  space                Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  pageVersions         PageVersion[]
  changeRequestsSource ChangeRequest[] @relation("SourceBranch")
  changeRequestsTarget ChangeRequest[] @relation("TargetBranch")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
}

model ChangeRequest {
  id             String              @id
  title          String
  status         ChangeRequestStatus @default(DRAFT)
  spaceId        String
  space          Space               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  sourceBranchId String
  sourceBranch   Branch              @relation("SourceBranch", fields: [sourceBranchId], references: [id], onDelete: Cascade)
  targetBranchId String
  targetBranch   Branch              @relation("TargetBranch", fields: [targetBranchId], references: [id], onDelete: Cascade)
  creatorId      String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

model PageVersion {
  id        String   @id @default(uuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  title     String
  content   String   @default("")
  updatedAt DateTime @updatedAt

  @@unique([pageId, branchId])
}

